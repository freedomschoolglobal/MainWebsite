---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';

const expect = [
  'A relaxed, no-pressure conversation — not a sales pitch',
  'Answers to your questions about learning, schedule and cost',
  'A clear sense of whether The Freedom School is right for your teen',
];

// Calendly inline embed (public scheduling link, themed in brand colours).
const calendlyUrl = `${site.calendly}?hide_gdpr_banner=1&primary_color=ee6c4d&background_color=ffffff&text_color=00373e`;
---

<BaseLayout
  title="Book a Call"
  description="Book a free intro call with The Freedom School. A relaxed conversation about your teen and how we can help — no pressure."
>
  <PageHero
    eyebrow="Let’s talk"
    title="Book a free intro call"
    lead="Pick a time that suits you and we’ll have a friendly chat about your teen — no pressure, no sales pitch."
    align="left"
  />

  <section class="section">
    <div class="container call-grid">
      <aside class="call-side">
        <h2>What to expect</h2>
        <ul class="expect">
          {expect.map((e) => (
            <li><Icon name="check" size={20} class="ex-ic" />{e}</li>
          ))}
        </ul>
        <p class="call-note">Choose a slot on the calendar and you’ll get an instant confirmation. We can’t wait to meet you.</p>
      </aside>

      <div class="cal-wrap">
        <div class="calendly-inline-widget" data-url={calendlyUrl} style="min-width:320px;height:720px;"></div>
        <noscript>
          <p class="cal-fallback">
            Please <a href={site.calendly} target="_blank" rel="noopener">open our booking page</a> to choose a time.
          </p>
        </noscript>
      </div>
    </div>
  </section>

  <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
</BaseLayout>

<style>
  .call-grid { display: grid; gap: 2.5rem; align-items: start; }
  @media (min-width: 920px) { .call-grid { grid-template-columns: 0.8fr 1.2fr; } }
  .call-side h2 { font-size: 1.5rem; margin-bottom: 1.25rem; }
  .expect { display: flex; flex-direction: column; gap: 0.9rem; }
  .expect li { display: flex; gap: 0.7rem; align-items: flex-start; }
  .ex-ic { color: var(--coral); flex: none; margin-top: 2px; }
  .call-note { margin-top: 1.75rem; color: var(--text-muted); font-size: var(--fs-sm); line-height: 1.6; }
  @media (min-width: 920px) { .call-side { position: sticky; top: 100px; } }

  .cal-wrap {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    padding: 0.25rem;
  }
  .cal-fallback { padding: 1.5rem; }
  .cal-fallback a { color: var(--blue-ink); text-decoration: underline; }
</style>
