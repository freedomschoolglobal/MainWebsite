---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import { values } from '../data/content';
---

<BaseLayout
  title="Mission & Values"
  description="Our mission is to harness technology to deliver inspiring, accessible, personalized education — giving every learner the freedom to succeed on their own path."
>
  <PageHero
    eyebrow="Mission & Values"
    title="Education that honors the whole young person"
    lead="Freedom within structure: we protect a small, essential foundation, and above it your child is free. That single idea shapes everything we believe and everything we do."
    coral={4}
  />

  <section class="section">
    <div class="container mission">
      <span class="pill-tag">Our mission</span>
      <p class="mission-statement">
        To give every young person a <span class="hl">guaranteed foundation</span> — and the <span class="hl">freedom to build on it</span> — so they walk out free, capable and good, and ready to thrive without us.
      </p>
      <div class="mission-points grid grid--3">
        <p><strong>We guarantee the floor.</strong> Reading and writing well, real-world numeracy, clear thinking, the ability to learn anything, and understanding how money and the world work — the capacities that keep every future open.</p>
        <p><strong>Above it, your child is free.</strong> What they study, how deep they go, what they build — that’s theirs to drive. The foundation isn’t the cage around freedom; it’s the launchpad beneath it.</p>
        <p><strong>Autonomy is grown, not granted.</strong> Freedom expands year over year as the capacity to use it well expands — from a wide, guided first year to a final year of real apprenticeships and stakes.</p>
      </div>
    </div>
  </section>

  <section class="section section--paper-2">
    <div class="container">
      <header class="section-head center">
        <p class="eyebrow">Our values</p>
        <h2>What we stand for</h2>
        <p class="lead measure mx-auto">Seven values guide every class, every project and every conversation at The Freedom School.</p>
      </header>
      <div class="grid grid--3 values-grid">
        {values.map((v, i) => (
          <article class="value-card">
            <span class="value-num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{v.title}</h3>
            <p>{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBand coral={7} />
</BaseLayout>

<style>
  .mission { text-align: center; max-width: 60rem; margin-inline: auto; }
  .mission .pill-tag { margin-bottom: 1.5rem; }
  .mission-statement {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.6rem, 1rem + 2.6vw, 2.6rem);
    line-height: 1.25;
    color: var(--ink);
    text-wrap: balance;
  }
  .mission-points { margin-top: 3rem; text-align: left; }
  .mission-points p { color: var(--text-muted); border-top: 3px solid var(--coral); padding-top: 1rem; }
  .mission-points strong { display: block; color: var(--ink); font-family: var(--font-display); margin-bottom: 0.3rem; }

  .value-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 1.75rem;
  }
  .value-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--coral-ink);
  }
  .value-card h3 { font-size: 1.25rem; margin: 0.5rem 0 0.5rem; }
  .value-card p { color: var(--text-muted); font-size: var(--fs-sm); }
</style>
