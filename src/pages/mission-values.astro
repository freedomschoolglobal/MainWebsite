---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import { values } from '../data/content';
---

<BaseLayout
  title="Mission & Values"
  description="Our mission is to harness technology to deliver inspiring, accessible, personalised education — giving every learner the freedom to succeed on their own path."
>
  <PageHero
    eyebrow="Mission & Values"
    title="Education that honours the whole young person"
    lead="At The Freedom School, life is inherently beautiful — curious, creative, expansive — and education should reflect that."
    coral={4}
  />

  <section class="section">
    <div class="container mission">
      <span class="pill-tag">Our mission</span>
      <p class="mission-statement">
        To harness technology to deliver <span class="hl">inspiring, accessible and personalised</span>
        education — giving every learner the freedom to succeed on their own path.
      </p>
      <div class="mission-points grid grid--3">
        <p>Learning for the joy of learning, led by each student’s curiosity and supported by experienced mentors.</p>
        <p>A wholesome approach — from academic subjects to moral, emotional, mental and physical wellbeing.</p>
        <p>The city, the parks, the land, the world as the campus — knowledge applied to real life, not just theory.</p>
      </div>
    </div>
  </section>

  <section class="section section--paper-2">
    <div class="container">
      <header class="section-head center">
        <p class="eyebrow">Our values</p>
        <h2>What we stand for</h2>
        <p class="lead measure mx-auto">Seven values guide every class, every project and every conversation at The Freedom School.</p>
      </header>
      <div class="grid grid--3 values-grid">
        {values.map((v, i) => (
          <article class="value-card">
            <span class="value-num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{v.title}</h3>
            <p>{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBand coral={7} />
</BaseLayout>

<style>
  .mission { text-align: center; max-width: 60rem; margin-inline: auto; }
  .mission .pill-tag { margin-bottom: 1.5rem; }
  .mission-statement {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.6rem, 1rem + 2.6vw, 2.6rem);
    line-height: 1.25;
    color: var(--ink);
    text-wrap: balance;
  }
  .mission-points { margin-top: 3rem; text-align: left; }
  .mission-points p { color: var(--text-muted); border-top: 3px solid var(--coral); padding-top: 1rem; }

  .value-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 1.75rem;
  }
  .value-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--coral-ink);
  }
  .value-card h3 { font-size: 1.25rem; margin: 0.5rem 0 0.5rem; }
  .value-card p { color: var(--text-muted); font-size: var(--fs-sm); }
</style>
