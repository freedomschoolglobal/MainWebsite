---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBand from '../../components/CtaBand.astro';
import Icon from '../../components/Icon.astro';
import CoralArt from '../../components/CoralArt.astro';
import { courses } from '../../data/curriculum';

export function getStaticPaths() {
  return courses.map((course) => ({
    params: { slug: course.slug },
    props: { course },
  }));
}

const { course } = Astro.props;
const related = courses.filter((c) => c.theme === course.theme && c.slug !== course.slug).slice(0, 3);
---

<BaseLayout title={`${course.title} — Curriculum`} description={course.summary}>
  <PageHero eyebrow={course.theme} title={course.title} lead={course.summary} coral={course.coral} align="left" />

  <section class="section">
    <div class="container class-grid">
      <div class="class-main">
        <h2>What you’ll learn</h2>
        <ul class="learn-list">
          {course.learn.map((item) => (
            <li><Icon name="check" size={20} class="learn-ic" />{item}</li>
          ))}
        </ul>

        <h2 class="how">How this class works</h2>
        <p>
          Like every Freedom School course, {course.title} is active and project-based. You’ll learn in small,
          live groups led by a Learning Leader, with plenty of discussion and time to apply ideas to something
          real. There’s no busywork — just genuine practice, useful feedback, and a chance to make the learning
          your own.
        </p>
      </div>

      <aside class="class-side">
        <div class="side-card">
          <CoralArt n={course.coral} size={120} class="side-coral" />
          <h3>At a glance</h3>
          <ul>
            <li><strong>Area</strong><span>{course.theme}</span></li>
            <li><strong>Format</strong><span>Live, small-group</span></li>
            <li><strong>Style</strong><span>Project-based</span></li>
            <li><strong>Level</strong><span>Ages 14–18</span></li>
          </ul>
          <a href="/apply" class="btn btn--coral">Apply now</a>
          <a href="/book-a-call" class="btn btn--outline">Book a call</a>
        </div>
      </aside>
    </div>
  </section>

  {related.length > 0 && (
    <section class="section section--paper-2">
      <div class="container">
        <header class="section-head"><p class="eyebrow">More in {course.theme}</p><h2>Related courses</h2></header>
        <div class="grid grid--3">
          {related.map((c) => (
            <a href={`/curriculum/${c.slug}`} class="rel-card">
              <h3>{c.title}</h3>
              <p>{c.summary}</p>
              <span class="link-arrow">Explore <Icon name="arrow-right" size={16} /></span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CtaBand coral={2} />
</BaseLayout>

<style>
  .class-grid { display: grid; gap: 2.5rem; align-items: start; }
  @media (min-width: 900px) { .class-grid { grid-template-columns: 1.5fr 0.9fr; } }
  .class-main h2 { font-size: 1.6rem; margin-bottom: 1rem; }
  .class-main .how { margin-top: 2.5rem; }
  .class-main p { color: var(--text-muted); line-height: 1.7; max-width: 60ch; }
  .learn-list { display: flex; flex-direction: column; gap: 0.85rem; }
  .learn-list li { display: flex; gap: 0.7rem; align-items: flex-start; }
  .learn-ic { color: var(--coral); margin-top: 2px; flex: none; }

  .side-card {
    position: relative;
    background: var(--cream); border-radius: var(--r-lg); padding: 1.75rem;
    position: sticky; top: 100px;
  }
  .side-coral { position: absolute; top: -28px; right: 12px; width: 92px; }
  .side-card h3 { font-size: 1.15rem; margin-bottom: 1rem; }
  .side-card ul { display: flex; flex-direction: column; gap: 0.7rem; margin-bottom: 1.5rem; }
  .side-card li { display: flex; justify-content: space-between; gap: 1rem; padding-bottom: 0.7rem; border-bottom: 1px solid var(--line); font-size: var(--fs-sm); }
  .side-card li strong { color: var(--ink); }
  .side-card li span { color: var(--text-muted); }
  .side-card .btn { width: 100%; margin-bottom: 0.6rem; }

  .rel-card {
    display: flex; flex-direction: column;
    background: #fff; border: 1px solid var(--line); border-radius: var(--r-lg); padding: 1.5rem;
    color: var(--ink); transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .rel-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); text-decoration: none; }
  .rel-card h3 { font-size: 1.15rem; margin-bottom: 0.5rem; }
  .rel-card p { color: var(--text-muted); font-size: var(--fs-sm); flex: 1; }
  .rel-card .link-arrow { margin-top: 1rem; }
</style>
