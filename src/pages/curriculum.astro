---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/Icon.astro';
import { curriculumTiers, teachingModes } from '../data/curriculum';
---

<BaseLayout
  title="Our Curriculum"
  description="The Freedom School curriculum is built in three layers — a foundation we guarantee, a shared inheritance everyone encounters, and a wide-open space your teen drives themselves. Protect the floor. Free the ceiling."
>
  <PageHero
    eyebrow="Our Curriculum"
    title="Protect the floor. Free the ceiling."
    lead="Most schools hand every student the same list of subjects and call it an education. We don’t. The Freedom School is built in three layers — a foundation we guarantee, a shared inheritance everyone encounters, and a wide-open space your teen drives themselves."
    coral={4}
  />

  <!-- THE THREE TIERS -->
  <section class="section">
    <div class="container">
      <ol class="tiers">
        {curriculumTiers.map((tier, i) => (
          <li class:list={['tier', `tier--${i + 1}`]}>
            <div class="tier-head">
              <span class="tier-num">{i + 1}</span>
              <div class="tier-head-text">
                <p class="tier-label">{tier.label} · <span>{tier.name}</span></p>
                <span class="tier-status">{tier.status}</span>
              </div>
            </div>
            <h2 class="tier-promise">{tier.promise}</h2>
            <p class="tier-body">{tier.body}</p>
            {tier.items && (
              <ul class="tier-items">
                {tier.items.map((it) => (
                  <li>
                    <Icon name="check" size={18} class="tier-tick" />
                    <span><strong>{it.title}</strong> — {it.note}</span>
                  </li>
                ))}
              </ul>
            )}
            {tier.footnote && <p class="tier-foot">{tier.footnote}</p>}
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- HOW IT'S TAUGHT (slim strip) -->
  <section class="section--tight taught">
    <div class="container">
      <p class="taught-intro">
        <span class="eyebrow">How it’s taught</span>
        Learning happens in four modes, not a timetable of periods.
      </p>
      <div class="grid grid--4 taught-grid">
        {teachingModes.map((m) => (
          <div class="taught-mode">
            <h3>{m.name}</h3>
            <p>{m.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CLOSING LINE -->
  <section class="section">
    <div class="container container--narrow center">
      <p class="curr-close">
        A guaranteed foundation. A shared inheritance. And the freedom to chase what matters to you.{' '}
        <span class="curr-close-hl">Protect the floor, free the ceiling — that’s the whole idea.</span>
      </p>
    </div>
  </section>

  <CtaBand title="Book a discovery call to explore your fit" coral={1} />
</BaseLayout>

<style>
  /* ---- Three tiers: a progression from guaranteed (1) to freely chosen (3) ---- */
  .tiers { display: flex; flex-direction: column; gap: clamp(1.25rem, 3vw, 2rem); }
  .tier {
    position: relative;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: clamp(1.6rem, 4vw, 2.8rem);
    background: var(--surface);
  }
  /* Cool, solid foundation → warm, open ceiling. */
  .tier--1 { background: var(--blue-panel); border-color: transparent; }
  .tier--2 { background: var(--paper-2); border-color: transparent; }
  .tier--3 {
    background: linear-gradient(160deg, var(--cream-2) 0%, #fff 80%);
    border-color: transparent;
  }

  .tier-head { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.1rem; }
  .tier-num {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--coral);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.3rem;
  }
  .tier--3 .tier-num { background: transparent; color: var(--coral-ink); border: 2px solid var(--coral); }
  .tier-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--coral-ink);
  }
  .tier-label span { color: var(--ink); }
  .tier-status {
    display: inline-block;
    margin-top: 0.25rem;
    font-size: var(--fs-xs);
    color: var(--text-muted);
  }
  .tier-promise {
    font-size: clamp(1.4rem, 1.1rem + 1.4vw, 2rem);
    margin-bottom: 0.7rem;
    text-wrap: balance;
  }
  .tier-body { color: var(--text-muted); line-height: 1.7; max-width: 62ch; }

  .tier-items {
    margin-top: 1.4rem;
    display: grid;
    gap: 0.7rem 1.5rem;
  }
  @media (min-width: 720px) { .tier-items { grid-template-columns: 1fr 1fr; } }
  .tier-items li { display: flex; gap: 0.6rem; align-items: flex-start; line-height: 1.45; }
  .tier-items span { font-size: var(--fs-sm); color: var(--text-muted); }
  .tier-items strong { color: var(--ink); font-weight: 600; }
  .tier-tick { color: var(--coral-ink); margin-top: 3px; flex: none; }

  .tier-foot {
    margin-top: 1.4rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--coral-ink);
  }

  /* ---- How it's taught (slim strip) ---- */
  .taught { background: var(--ink); color: var(--text-on-dark); padding-block: clamp(2.5rem, 5vw, 4rem); }
  .taught-intro { margin-bottom: 1.8rem; color: var(--text-on-dark); }
  .taught-intro .eyebrow { display: block; color: var(--peach); margin-bottom: 0.5rem; }
  .taught-grid { gap: clamp(1.2rem, 3vw, 2rem); }
  .taught-mode { border-top: 2px solid rgba(255, 255, 255, 0.25); padding-top: 0.9rem; }
  .taught-mode h3 { font-size: 1.15rem; color: #fff; margin-bottom: 0.3rem; }
  .taught-mode p { font-size: var(--fs-sm); color: var(--text-on-dark-muted); line-height: 1.5; }

  /* ---- Closing line ---- */
  .curr-close {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.4rem, 1rem + 2vw, 2.1rem);
    line-height: 1.35;
    color: var(--ink);
    max-width: 46rem;
    margin-inline: auto;
    text-wrap: balance;
  }
  .curr-close-hl { color: var(--coral-ink); }
</style>
