---
import { footerNav, legalNav, site } from '../data/site';
import Icon from './Icon.astro';
import Logo from './Logo.astro';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="f-brand" aria-label={`${site.name} — home`}>
        <Logo />
      </a>
      <p class="f-tagline">A fully online high school teaching teens how to think — not what to think.</p>
      <div class="socials">
        {
          site.socials.map((s) => (
            <a href={s.href} class="social" target="_blank" rel="noopener" aria-label={`${s.label} (opens in a new tab)`}>
              <Icon name={s.icon} size={20} />
            </a>
          ))
        }
      </div>
    </div>

    {
      footerNav.map((col) => (
        <nav class="footer-col" aria-label={col.title}>
          <h2 class="footer-heading">{col.title}</h2>
          <ul>
            {col.links.map((l) => (
              <li>
                <a href={l.href}>{l.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }
  </div>

  <div class="container footer-bottom">
    <div class="footer-credit">
      <p class="copyright">© {year} {site.name}. All rights reserved.</p>
      <p class="credit">Site design &amp; build by <a href="https://robbielockie.com" target="_blank" rel="noopener">Robbie Lockie</a></p>
    </div>
    <ul class="legal">
      {legalNav.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    /* Soft pastel band: mint + peach tints over a warm cream base */
    background:
      radial-gradient(85% 120% at 0% 0%, var(--mint) 0%, transparent 58%),
      radial-gradient(75% 120% at 100% 0%, #ffe3cf 0%, transparent 55%),
      #fbf4ec;
    color: var(--text-muted);
    padding-block: clamp(3rem, 6vw, 4.5rem) 1.75rem;
    border-top: 1px solid rgba(0, 55, 62, 0.08);
  }
  .footer-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .footer-grid { grid-template-columns: 1.6fr repeat(3, 1fr); gap: 2rem; }
  }

  .f-brand { display: inline-flex; align-items: center; color: var(--ink); }
  .f-brand:hover { text-decoration: none; }
  .f-tagline {
    margin-top: 1.1rem;
    max-width: 32ch;
    color: var(--text-muted);
    font-size: var(--fs-sm);
    line-height: 1.6;
  }
  .socials { display: flex; gap: 0.6rem; margin-top: 1.3rem; }
  .social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    color: var(--ink);
    background: rgba(0, 55, 62, 0.05);
    border: 1px solid rgba(0, 55, 62, 0.12);
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease, border-color 0.18s ease;
  }
  .social:hover { background: var(--coral-strong); color: #fff; border-color: transparent; transform: translateY(-2px); }

  .footer-heading {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--coral-ink);
    margin-bottom: 1rem;
  }
  .footer-col ul { display: flex; flex-direction: column; gap: 0.6rem; }
  .footer-col a { color: var(--text-muted); font-size: var(--fs-sm); transition: color 0.15s ease; }
  .footer-col a:hover { color: var(--ink); text-decoration: none; }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    align-items: center;
    justify-content: space-between;
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    padding-top: 1.5rem;
    border-top: 1px solid rgba(0, 55, 62, 0.12);
  }
  .footer-credit { display: flex; flex-direction: column; gap: 0.3rem; }
  .copyright { color: var(--text-muted); font-size: var(--fs-xs); }
  .credit { color: var(--text-muted); font-size: var(--fs-xs); }
  .credit a { color: var(--coral-ink); font-weight: 500; }
  .credit a:hover { color: var(--ink); text-decoration: none; }
  .legal { display: flex; flex-wrap: wrap; gap: 0.5rem 1.25rem; }
  .legal a { color: var(--text-muted); font-size: var(--fs-xs); }
  .legal a:hover { color: var(--ink); text-decoration: none; }
</style>
