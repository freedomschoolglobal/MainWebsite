---
import { footerNav, legalNav, site } from '../data/site';
import Icon from './Icon.astro';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="f-brand" aria-label={`${site.name} — home`}>
        <svg class="bloom" viewBox="0 0 48 48" aria-hidden="true" width="40" height="40">
          <g>
            <g fill="#ee6c4d">
              {Array.from({ length: 8 }).map((_, i) => (
                <ellipse cx="24" cy="11" rx="5" ry="11" transform={`rotate(${i * 45} 24 24)`} />
              ))}
            </g>
            <g fill="#ffd9a0">
              {Array.from({ length: 8 }).map((_, i) => (
                <ellipse cx="24" cy="16" rx="3.4" ry="7.5" transform={`rotate(${i * 45 + 22.5} 24 24)`} />
              ))}
            </g>
            <circle cx="24" cy="24" r="4.6" fill="#fff" />
          </g>
        </svg>
        <span class="f-wordmark">The Freedom<br />School</span>
      </a>
      <p class="f-tagline">A fully online high school teaching teens how to think — not what to think.</p>
      <div class="socials">
        {
          site.socials.map((s) => (
            <a href={s.href} class="social" target="_blank" rel="noopener" aria-label={`${s.label} (opens in a new tab)`}>
              <Icon name={s.icon} size={20} />
            </a>
          ))
        }
      </div>
    </div>

    {
      footerNav.map((col) => (
        <nav class="footer-col" aria-label={col.title}>
          <h2 class="footer-heading">{col.title}</h2>
          <ul>
            {col.links.map((l) => (
              <li>
                <a href={l.href}>{l.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }
  </div>

  <div class="container footer-bottom">
    <p class="copyright">© {year} {site.name}. All rights reserved.</p>
    <ul class="legal">
      {legalNav.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: var(--text-on-dark);
    padding-block: clamp(3rem, 6vw, 4.5rem) 1.75rem;
  }
  .footer-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .footer-grid { grid-template-columns: 1.6fr repeat(3, 1fr); gap: 2rem; }
  }

  .f-brand { display: inline-flex; align-items: center; gap: 0.7rem; }
  .f-brand:hover { text-decoration: none; }
  .f-wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.05;
    color: #fff;
    letter-spacing: -0.02em;
  }
  .f-tagline {
    margin-top: 1.1rem;
    max-width: 32ch;
    color: var(--text-on-dark-muted);
    font-size: var(--fs-sm);
    line-height: 1.6;
  }
  .socials { display: flex; gap: 0.6rem; margin-top: 1.3rem; }
  .social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    transition: background 0.18s ease, transform 0.18s ease;
  }
  .social:hover { background: var(--coral-strong); transform: translateY(-2px); }

  .footer-heading {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--peach);
    margin-bottom: 1rem;
  }
  .footer-col ul { display: flex; flex-direction: column; gap: 0.6rem; }
  .footer-col a {
    color: var(--text-on-dark-muted);
    font-size: var(--fs-sm);
    transition: color 0.15s ease;
  }
  .footer-col a:hover { color: #fff; text-decoration: none; }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    align-items: center;
    justify-content: space-between;
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }
  .copyright { color: var(--text-on-dark-muted); font-size: var(--fs-xs); }
  .legal { display: flex; flex-wrap: wrap; gap: 0.5rem 1.25rem; }
  .legal a { color: var(--text-on-dark-muted); font-size: var(--fs-xs); }
  .legal a:hover { color: #fff; text-decoration: none; }
</style>
