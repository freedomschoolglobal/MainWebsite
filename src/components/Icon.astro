};

const svg = icons[name] ?? '';
---
<span class={`icon ${cls}`.trim()} style={`width:${size}px;height:${size}px`} aria-hidden="true" set:html={svg}></span>

<style>
  .icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: none;
    line-height: 0;
  }
  .icon :global(svg) { width: 100%; height: 100%; }
</style>
