---
import CoralArt from './CoralArt.astro';

interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  coral?: number; // show decorative coral if set
  align?: 'center' | 'left';
}
const { eyebrow, title, lead, coral, align = 'center' } = Astro.props;
const hasSlot = Astro.slots.has('default');
---

<section class="page-hero" data-align={align}>
  {coral && (
    <div class="ph-art" aria-hidden="true">
      <CoralArt n={coral} size={300} />
    </div>
  )}
  <div class="container ph-inner">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {lead && <p class="lead">{lead}</p>}
    {hasSlot && <div class="ph-actions"><slot /></div>}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    overflow: clip;
    padding-block: clamp(3.5rem, 8vw, 6rem) clamp(2.5rem, 5vw, 4rem);
    background:
      radial-gradient(120% 120% at 85% -10%, var(--cream-2) 0%, transparent 55%),
      radial-gradient(110% 130% at 0% 0%, var(--mint) 0%, transparent 45%),
      var(--paper);
  }
  .ph-inner { position: relative; z-index: 1; max-width: 56rem; }
  .page-hero[data-align='center'] .ph-inner { margin-inline: auto; text-align: center; }
  .page-hero[data-align='center'] .lead { margin-inline: auto; }
  .page-hero .eyebrow { margin-bottom: 0.9rem; }
  .page-hero h1 { font-size: var(--fs-display); }
  .page-hero .lead { margin-top: 1.1rem; max-width: 60ch; }
  .ph-actions { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 1.8rem; }
  .page-hero[data-align='center'] .ph-actions { justify-content: center; }

  .ph-art {
    position: absolute;
    top: -40px;
    right: -40px;
    width: clamp(180px, 26vw, 320px);
    opacity: 0.9;
    z-index: 0;
  }
  @media (max-width: 760px) { .ph-art { opacity: 0.5; right: -70px; width: 200px; } }
</style>
