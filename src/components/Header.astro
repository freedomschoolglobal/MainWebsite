---
import Logo from './Logo.astro';
import { mainNav, site } from '../data/site';
import Icon from './Icon.astro';

interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class:list={['site-header', transparent && 'is-transparent']} data-header>
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={`${site.name} — home`}>
      <Logo />
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul class="nav-list">
        {
          mainNav.map((item) =>
            item.children ? (
              <li class="nav-item has-children">
                <a
                  href={item.href}
                  class:list={['nav-link', isActive(item.href) && 'is-active']}
                  aria-haspopup="true"
                >
                  {item.label}
                  <Icon name="chevron-down" size={15} />
                </a>
                <div class="dropdown" role="menu">
                  <ul>
                    {item.children.map((c) => (
                      <li role="none">
                        <a role="menuitem" href={c.href} class:list={['dropdown-link', isActive(c.href) && 'is-active']}>
                          {c.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </li>
            ) : (
              <li class="nav-item">
                <a href={item.href} class:list={['nav-link', isActive(item.href) && 'is-active']}>
                  {item.label}
                </a>
              </li>
            )
          )
        }
      </ul>
    </nav>

    <div class="header-actions">
      <a href={site.cta.secondary.href} class="btn btn--outline btn--sm">{site.cta.secondary.label}</a>
      <a href={site.cta.primary.href} class="btn btn--coral btn--sm">{site.cta.primary.label}</a>
    </div>

    <button class="menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" data-menu-open>
      <Icon name="menu" size={26} />
    </button>
  </div>
</header>

<div class="mobile-menu" id="mobile-menu" data-mobile-menu hidden>
    <div class="mobile-head container">
      <span class="m-brand">{site.name}</span>
      <button class="menu-toggle" aria-label="Close menu" data-menu-close>
        <Icon name="close" size={26} />
      </button>
    </div>
    <nav class="container mobile-nav" aria-label="Mobile">
      <ul class="m-list">
        {
          mainNav.map((item) =>
            item.children ? (
              <li>
                <details>
                  <summary>
                    {item.label}
                    <Icon name="chevron-down" size={18} />
                  </summary>
                  <ul class="m-sub">
                    {item.children.map((c) => (
                      <li>
                        <a href={c.href}>{c.label}</a>
                      </li>
                    ))}
                  </ul>
                </details>
              </li>
            ) : (
              <li>
                <a class="m-top" href={item.href}>
                  {item.label}
                </a>
              </li>
            )
          )
        }
      </ul>
      <div class="m-actions">
        <a href={site.cta.secondary.href} class="btn btn--outline">{site.cta.secondary.label}</a>
        <a href={site.cta.primary.href} class="btn btn--coral">{site.cta.primary.label}</a>
      </div>
    </nav>
  </div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid transparent;
    transition: box-shadow 0.25s ease, border-color 0.25s ease, background 0.25s ease;
  }
  .site-header.is-scrolled {
    border-color: var(--line);
    box-shadow: 0 6px 24px rgba(0, 55, 62, 0.06);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    min-height: 76px;
  }
  .brand { display: inline-flex; align-items: center; flex: none; color: var(--ink); }
  .brand:hover { text-decoration: none; }

  .primary-nav { margin-inline-start: auto; }
  .nav-list { display: flex; align-items: center; gap: 0.35rem; }
  .nav-item { position: relative; }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    padding: 0.55rem 0.85rem;
    border-radius: var(--r-pill);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1rem;
    color: var(--ink);
    transition: background 0.18s ease, color 0.18s ease;
  }
  .nav-link:hover { background: rgba(0, 55, 62, 0.06); text-decoration: none; }
  .nav-link.is-active { color: var(--coral-ink); }
  .has-children > .nav-link :global(.icon) { transition: transform 0.2s ease; opacity: 0.7; }
  .nav-item.has-children:hover > .nav-link :global(.icon),
  .nav-item.has-children:focus-within > .nav-link :global(.icon) { transform: rotate(180deg); }

  .dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    min-width: 244px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r);
    box-shadow: var(--shadow-lg);
    padding: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
  }
  .nav-item.has-children:hover .dropdown,
  .nav-item.has-children:focus-within .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .dropdown-link {
    display: block;
    padding: 0.6rem 0.8rem;
    border-radius: var(--r-sm);
    font-size: var(--fs-sm);
    color: var(--ink);
  }
  .dropdown-link:hover { background: var(--cream); text-decoration: none; }
  .dropdown-link.is-active { background: var(--mint); color: var(--coral-ink); }

  .header-actions { display: flex; align-items: center; gap: 0.6rem; flex: none; }

  .menu-toggle { display: none; color: var(--ink); padding: 0.4rem; border-radius: 10px; }
  .menu-toggle:hover { background: rgba(0, 55, 62, 0.06); }

  /* Mobile menu panel */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: var(--paper);
    overflow-y: auto;
    padding-bottom: 2rem;
  }
  .mobile-menu[hidden] { display: none; }
  .mobile-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 76px;
  }
  .m-brand { font-family: var(--font-display); font-weight: 700; font-size: 1.1rem; color: var(--ink); }
  .mobile-nav { padding-top: 0.5rem; }
  .m-list { display: flex; flex-direction: column; gap: 0.25rem; }
  .m-list a, .m-list summary {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--ink);
  }
  .m-top, .m-list summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.95rem 0.4rem;
    font-size: 1.2rem;
    border-bottom: 1px solid var(--line);
    cursor: pointer;
    list-style: none;
  }
  .m-list summary::-webkit-details-marker { display: none; }
  details[open] summary :global(.icon) { transform: rotate(180deg); }
  .m-sub { padding: 0.25rem 0 0.75rem 0.4rem; display: flex; flex-direction: column; }
  .m-sub a { padding: 0.6rem 0.4rem; font-weight: 400; font-size: 1.02rem; color: var(--text-muted); }
  .m-actions { display: flex; flex-direction: column; gap: 0.7rem; margin-top: 1.5rem; }
  .m-actions .btn { width: 100%; }

  @media (max-width: 980px) {
    .primary-nav, .header-actions { display: none; }
    .menu-toggle { display: inline-flex; margin-inline-start: auto; }
  }

  /* ---- Transparent overlay variant (immersive home hero) ---- */
  .site-header.is-transparent {
    position: fixed;
    top: 0; left: 0; right: 0;
    background: transparent;
    backdrop-filter: none;
    border-color: transparent;
  }
  .site-header.is-transparent .nav-link { color: #fff; }
  .site-header.is-transparent .nav-link:hover { background: rgba(255, 255, 255, 0.16); }
  .site-header.is-transparent .nav-link.is-active { color: var(--peach); }
  .site-header.is-transparent .brand { color: #fff; text-shadow: 0 1px 14px rgba(0, 0, 0, 0.4); }
  .site-header.is-transparent .menu-toggle { color: #fff; }
  .site-header.is-transparent .menu-toggle:hover { background: rgba(255, 255, 255, 0.16); }
  .site-header.is-transparent .btn--outline { border-color: rgba(255, 255, 255, 0.55); color: #fff; }
  .site-header.is-transparent .btn--outline:hover { border-color: #fff; background: rgba(255, 255, 255, 0.12); }

  /* Becomes solid once the user scrolls */
  .site-header.is-transparent.is-scrolled {
    background: color-mix(in srgb, var(--paper) 92%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    border-color: var(--line);
    box-shadow: 0 6px 24px rgba(0, 55, 62, 0.06);
  }
  .site-header.is-transparent.is-scrolled .nav-link { color: var(--ink); }
  .site-header.is-transparent.is-scrolled .nav-link.is-active { color: var(--coral-ink); }
  .site-header.is-transparent.is-scrolled .brand { color: var(--ink); text-shadow: none; }
  .site-header.is-transparent.is-scrolled .menu-toggle { color: var(--ink); }
  .site-header.is-transparent.is-scrolled .btn--outline { border-color: var(--line-strong); color: var(--ink); }
</style>

<script>
  const header = document.querySelector('[data-header]');
  const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const openBtn = document.querySelector<HTMLButtonElement>('[data-menu-open]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-menu-close]');

  const setMenu = (open: boolean) => {
    if (!menu) return;
    menu.hidden = !open;
    openBtn?.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
    if (open) menu.querySelector<HTMLElement>('a, button, summary')?.focus();
  };

  openBtn?.addEventListener('click', () => setMenu(true));
  closeBtn?.addEventListener('click', () => setMenu(false));
  menu?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('a')) setMenu(false);
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu && !menu.hidden) setMenu(false);
  });
</script>
